USE company_db;
CREATE TABLE sales (
    sale_id INT PRIMARY KEY,
    product_id INT,
    quantity INT,
    customer_id INT
);

INSERT INTO sales VALUES
(1, 101, 5, 201),
(2, 102, 2, 202),
(3, 101, 3, 203),
(4, 103, 1, 204),
(5, 104, 7, 205);

-- Display details
SHOW INDEX FROM sales;

-- Create the index for a column
CREATE INDEX index_product 
ON sales(product_id);

-- Multiple index merging
CREATE INDEX index_product__ 
ON sales(product_id,quantity);

-- delete index
DROP INDEX index_product ON sales;

-- change name
ALTER TABLE sales 
RENAME INDEX index_product to index_pro;

-- add index using alter
ALTER TABLE sales 
ADD INDEX idx_cus(customer_id);

