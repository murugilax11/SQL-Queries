-- function using if-else
CREATE DATABASE procedure_db;
USE procedure_db;
CREATE TABLE accountsss(acc_id INT PRIMARY KEY, acc_name VARCHAR(30), balance decimal(10,2));
INSERT INTO accountsss VALUES(101,'kiruba',50000),(102,'murugi',10000);

delimiter $$
CREATE PROCEDURE transfer_money_1(IN kiruba INT ,IN murugi INT, 
IN amount DECIMAL(10,2), OUT msg VARCHAR(30))
BEGIN
   declare kiruba_bal DECIMAL(10,2);
   SELECT balance INTO kiruba_bal FROM accountsss
   WHERE acc_id = kiruba;
   
   IF kiruba_bal >= amount THEN
      START TRANSACTION;
      UPDATE accountsss
      SET balance = balance -amount
      WHERE acc_id = kiruba;
      UPDATE accountsss
      SET balance = balance + amount
      WHERE acc_id = murugi;
      COMMIT;
      SET msg = 'successful transaction';
  ELSE 
      SET msg = 'insufficient balance';
  END IF;
END $$
delimiter ;

CALL transfer_money_1(101,102,5000, @result);
SELECT @result;

