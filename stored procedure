-- types of loops using in the stored procedure
-- basic loop with stored procedure
use procedure_db;
delimiter $$
CREATE PROCEDURE basicLoop()
BEGIN
 DECLARE i INT;
 SET i=1;
looplabel: LOOP
   IF i >10 THEN
     LEAVE looplabel;
   END IF;
   SET i = i+1;
END LOOP;
   SELECT i;
END $$
delimiter ;
CALL basicLoop();

-- While loop
delimiter $$
CREATE PROCEDURE whileLoop()
BEGIN
 DECLARE i INT;
 SET i=1;
   WHILE i <= 10 DO
   SET i = i+1;
END WHILE;
   SELECT i;
END $$
delimiter ;
CALL whileLoop();

-- Repeat with procedure
delimiter $$
CREATE PROCEDURE repeatLoop()
BEGIN
 DECLARE i INT;
 SET i=1;
REPEAT
   SET i = i+1;
   UNTIL i > 10
END REPEAT;
   SELECT i;
END $$
delimiter ;
CALL repeatLoop();

 
