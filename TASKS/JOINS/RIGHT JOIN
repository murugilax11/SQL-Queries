(102,'Divya',2);
-- 28. Show all courses with enrolled students.
SELECT c.course_name, s.student_name
FROM courses AS c
RIGHT JOIN std AS s
ON c.course_id = s.course_id;

-- 29. Find courses with no students enrolled.
SELECT c.course_name, s.student_name
FROM std AS s
RIGHT JOIN courses AS c
ON c.course_id = s.course_id
WHERE s.student_id IS NULL;

