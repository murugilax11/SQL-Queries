-- 1. Find employees along with their manager names
SELECT e1.emp_name AS employee,
e2.emp_name AS manager
FROM employees1 AS e1
JOIN employees1 AS e2
ON e1.manager_id = e2.emp_id;

-- 2. Display employees who earn more than their managers
SELECT e.emp_name AS employee,
m.emp_name AS manager
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
WHERE e.salary > m.salary;

-- 3. Find employees working in the same department as their manager
SELECT e.emp_name, m.emp_name
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
WHERE e.department = m.department;

-- 4. Show all employee pairs working in the same department
SELECT e1.emp_name AS employee1, e2.emp_name AS employee2, e1.department
FROM Employees1 AS e1
JOIN Employees1 AS e2
ON e1.department = e2.department
WHERE e1.emp_id > e2.emp_id;

-- 5. Find employees who joined earlier than their managers
SELECT e.emp_name AS employee,m.emp_name AS manager
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
AND e.joining_date < m.joining_date;

-- 6. Display employees and their manager salaries
SELECT e.emp_name AS employee,e.salary AS employee_salary,
m.emp_name AS manager, m.salary AS manager_salary
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id;

-- 7. Find employees whose manager is from the HR department
SELECT e.emp_name AS employee
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
WHERE m.department = 'HR';

-- 8. List employees who do not have managers
SELECT * FROM Employees1
WHERE manager_id IS NULL;

-- 9. Find manager names with the number of employees under them
SELECT COUNT(e.emp_id) AS total_emp, m.emp_name
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
GROUP BY m.emp_id, m.emp_name;

-- 10. Display employees having the same salary as their managers
SELECT e.emp_name , e.salary 
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
WHERE e.salary = m.salary;  

-- 11. Find employees whose manager joined in the same year
SELECT e.emp_name AS employee
FROM Employees1 AS e
JOIN Employees1 As m
ON e.manager_id = m.emp_id
WHERE YEAR(e.joining_date) = YEAR(m.joining_date);

-- 12. Show hierarchy levels up to manager’s manager
SELECT e.emp_name AS employee,
m.emp_name AS manager,
mm.emp_name AS managers_manager
FROM Employees1 AS e
JOIN Employees1 AS m
ON e.manager_id = m.emp_id
JOIN employees1 AS mm
ON m.manager_id = mm.emp_id;
