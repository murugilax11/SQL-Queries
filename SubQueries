INSERT INTO PSR VALUES (106,'murugi','IT',45000);

CREATE TABLE departments( dept_id INT , department VARCHAR(50) PRIMARY KEY,location VARCHAR(50));
INSERT INTO departments VALUES(1,'IT','Chennai'), (2,'Finance','Coimbatore'), (3,'HR','Bangalure');

-- Single row Subquery

-- print employee from dep_id = 2
SELECT * FROM PSR WHERE department =(
SELECT department FROM departments WHERE dept_id = 2);

-- find employee who earing more than david
SELECT * FROM PSR WHERE salary > ( 
SELECT salary FROM PSR WHERE emp_name = 'Davit');

-- find employees working in the same department as davit
SELECT * from PSR 
WHERE department =
(SELECT department
FROM PSR WHERE emp_name = 'David');

-- find employee whose salary is less than average salary
SELECT * FROM PSR
WHERE salary <
(SELECT AVG(salary) FROM PSR);

-- Multi row Subquery

-- find employees working in department located from banglore
SELECT *
FROM PSR
WHERE department IN (
SELECT department
FROM departments
WHERE location = 'Bangalure');

-- find employees whose salary matches salarys of hr department
SELECT emp_name FROM PSR WHERE salary IN
(SELECT salary 
FROM PSR 
WHERE department = 'HR') AND department <> "HR";

-- find employee earing more than any employee in hr
SELECT * FROM PSR WHERE salary > ANY
(SELECT salary 
FROM PSR 
WHERE department = 'HR');

-- CO-related subquery

-- find the employee mothan then average salary department wise
SELECT * FROM PSR  AS t1
WHERE salary >
(SELECT AVG(salary) FROM PSR 
WHERE department = t1.department);

-- find employees having the highest salary of their department
SELECT * FROM PSR AS t1
WHERE salary =
(SELECT MAX(salary) FROM PSR WHERE department = t1.department);

-- find employees whose salary is below their department
SELECT *  FROM PSR AS t1
WHERE salary <(
SELECT MIN(salary) FROM PSR WHERE department = t1.department);

